# =============================================================================
# StreamCast — variables d'environnement de production
# Copié vers /etc/streamcast/streamcast.env par install.sh (chmod 600).
# Après modification : systemctl restart streamcast-app
# =============================================================================

# Mot de passe du panel /panel (OBLIGATOIRE en production — sinon accès libre).
# install.sh en génère un aléatoire au premier lancement.
APP_PASSWORD=changez-moi

# Clé API Anthropic — uniquement pour les outils IA annexes du dépôt
# (Studio…). Inutile pour le streaming : laissez vide si non utilisé.
#ANTHROPIC_API_KEY=

# Ne JAMAIS activer en production : autorise les URLs privées (anti-SSRF off).
#STREAMCAST_ALLOW_PRIVATE=
