# Viral AI OS — variables d'environnement (copie ce fichier en .env.local)

# Clé API Claude (Anthropic). Sans elle, l'app tourne en "mode local" (sans IA réelle).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Base de données (chemin de production avec Prisma). Non utilisé par le store JSON local.
# SQLite : "file:./prisma/dev.db"   |   PostgreSQL : "postgresql://user:pass@host:5432/db"
DATABASE_URL="file:./prisma/dev.db"

# Mot de passe du panel /panel (gestion des chaînes M3U/Xtream). Vide = panel ouvert (local uniquement).
# Protégé contre la force brute (temporisation croissante après plusieurs échecs).
APP_PASSWORD=

# StreamCast — anti-SSRF. Par défaut, le serveur refuse de télécharger des URLs internes
# (localhost, réseau privé, métadonnées cloud) lors des imports M3U/EPG/test de santé.
# Mettez 1 UNIQUEMENT en développement local si vos sources sont sur localhost/réseau privé.
STREAMCAST_ALLOW_PRIVATE=
