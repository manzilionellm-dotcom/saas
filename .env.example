# Simultaneous-login detection (single-session enforcement).
# Default: false — multiple simultaneous sessions per user are allowed and a
# new login never invalidates, warns about, or disconnects existing sessions.
# Set to "true" to make a new login revoke the user's other active sessions.
SIMULTANEOUS_LOGIN_DETECTION_ENABLED=false

# Access-token lifetime in seconds (default: 900 = 15 minutes).
# SESSION_TTL_SECONDS=900

# Refresh-token lifetime in seconds (default: 604800 = 7 days).
# REFRESH_TTL_SECONDS=604800
