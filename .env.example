# Copy to .env and fill in. Never commit the real .env.

# SQLite database used by Prisma / Auth.js.
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate one with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="replace-me"

# Public URL of the app (used to derive the WebAuthn origin / RP ID).
AUTH_URL="http://localhost:3000"

# Trust the incoming host header (needed when self-hosting behind a proxy).
AUTH_TRUST_HOST="true"
