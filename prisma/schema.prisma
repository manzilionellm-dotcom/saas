// Schéma canonique de Viral AI OS (chemin de production).
//
// Dans ce bac à sable, Prisma ne peut pas télécharger ses binaires moteur
// (politique réseau). La couche de données tourne donc via une abstraction
// `Repository` (implémentation fichier JSON — voir app/lib/db/).
//
// Pour passer en production : `npm i prisma @prisma/client`, `npx prisma migrate dev`,
// puis brancher une implémentation `PrismaRepository` derrière la même interface.
// Passage SQLite -> PostgreSQL = changer `provider` ci-dessous.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id                String       @id @default(cuid())
  name              String
  businessType      String
  country           String
  locale            String // langue principale, ex "fr"
  additionalLocales String? // JSON: ["ar","sv"]
  targetCustomer    String
  budget            String
  mainGoal          String
  brandVoice        String? // ton, couleurs, tagline, do/don't
  notes             String?
  createdAt         DateTime     @default(now())
  generations       Generation[]
  briefs            DailyBrief[]
  competitors       Competitor[]
}

model Generation {
  id            String     @id @default(cuid())
  businessId    String
  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  platform      String
  kind          String // hooks | script | post | hashtags | seo_title | ad_copy
  locale        String
  prompt        String
  output        String
  promptVersion String // version du template utilisé
  tokensUsed    Int?
  costEstimate  Float?
  createdAt     DateTime   @default(now())
  results       Result[]
}

model Result {
  id           String     @id @default(cuid())
  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  views        Int?
  likes        Int?
  clicks       Int?
  conversions  Int?
  note         String?
  recordedAt   DateTime   @default(now())
}

model DailyBrief {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  content    String // JSON: { angles[], stop, opportunity }
  date       DateTime @default(now())
}

model Competitor {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  source     String // meta_ad_library | ...
  lastData   String? // JSON brut de la dernière récupération
  updatedAt  DateTime @updatedAt
}

model LLMLog {
  id         String   @id @default(cuid())
  provider   String
  input      String
  output     String?
  tokensUsed Int?
  latencyMs  Int?
  error      String?
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Produit « Dropshipping Copilot ». Miroir de app/lib/dropship/types.ts.
// Le runtime tourne via le store JSON (.data/dropshipping.json) ; ces modèles
// décrivent le chemin de production Prisma/Postgres (PrismaDropshipRepository).
// ---------------------------------------------------------------------------

model DropshippingProject {
  id         String             @id @default(cuid())
  userId     String // fourni par le SaaS parent (auth)
  name       String
  status     String // market_research | product_validation | ... | killed
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  candidates ProductCandidate[]
}

model ProductCandidate {
  id                          String                    @id @default(cuid())
  projectId                   String
  project                     DropshippingProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rawDescription              String
  productName                 String?
  investmentCommitteeDecision String? // GO | HOLD | REJECT | null
  decisionRationale           String
  createdAt                   DateTime                  @default(now())
  supplierInput               SupplierValidationInput?
  compliance                  ComplianceCheck?
  financialModel              FinancialModel?
  adRuleSet                   AdRuleSet?
  weeklyMetrics               WeeklyMetricEntry[]
  reports                     AgentReport[]
  gates                       ApprovalGate[]
}

model SupplierValidationInput {
  id                 String           @id @default(cuid())
  productCandidateId String           @unique
  candidate          ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  productNameInput   String
  productUrl         String
  supplierName       String
  productCost        Float?
  shippingCost       Float?
  deliveryDays       Int?
  warehouseLocation  String
  supplierRating     Float?
  orderVolume        String
  reviewCount        Int?
  averageReviewScore Float?
  recurringComplaints String
  stockStability     String
  priceChangeHistory String
  availableVariants  String
  complianceDocs     String
  returnRefundSignals String
  verdict            String // PASS | FAIL | NEEDS_MORE_DATA
  verdictReasons     String // JSON string[]
  createdAt          DateTime         @default(now())
}

model ComplianceCheck {
  id                          String           @id @default(cuid())
  productCandidateId          String           @unique
  candidate                   ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  vatOss                      String // n/a | to_verify | verified
  gpsr                        String
  ceMarking                   String
  batteryReg                  String
  weee                        String
  withdrawalRight             String
  euResponsiblePerson         String
  gdpr                        String
  professionalReviewConfirmed Boolean          @default(false)
  createdAt                   DateTime         @default(now())
}

model FinancialModel {
  id                    String           @id @default(cuid())
  productCandidateId    String           @unique
  candidate             ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  productCost           Float
  shippingCost          Float
  transactionFeeRate    Float
  targetGrossMarginRate Float
  adCushionRate         Float
  computedLandedCost    Float
  computedSellingPrice  Float
  computedBreakEvenCPA  Float
  computedMaxCPA        Float
  computedBreakEvenROAS Float
  warnings              String // JSON string[]
  createdAt             DateTime         @default(now())
}

model AdRuleSet {
  id                 String           @id @default(cuid())
  productCandidateId String           @unique
  candidate          ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  rules              String // JSON
  status             String // draft | active | archived
  createdAt          DateTime         @default(now())
}

model WeeklyMetricEntry {
  id                     String           @id @default(cuid())
  productCandidateId     String
  candidate              ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  weekStartDate          String
  spend                  Float
  revenue                Float
  cpa                    Float
  roas                   Float
  ctr                    Float
  cpc                    Float
  conversionRate         Float
  aov                    Float
  refundRate             Float
  recommendation         String // SCALE | HOLD | ITERATE | KILL
  recommendationRationale String
  createdAt              DateTime         @default(now())
}

model AgentReport {
  id                 String           @id @default(cuid())
  productCandidateId String
  candidate          ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  agentRole          String
  stage              String // market_research | product_validation | brand_build | marketing_plan | launch
  content            String
  claimsAudit        String // JSON: Claim[]
  confidenceLevel    String // high | medium | low
  createdAt          DateTime         @default(now())
}

model ApprovalGate {
  id                 String           @id @default(cuid())
  productCandidateId String
  candidate          ProductCandidate @relation(fields: [productCandidateId], references: [id], onDelete: Cascade)
  gateName           String // market_to_product | product_to_brand | brand_to_marketing | marketing_to_launch
  approvedByUser     Boolean          @default(false)
  approvedAt         DateTime?

  @@unique([productCandidateId, gateName])
}
